class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        n=len(nums)
        majority_element=n//2
        for i in range(n):
            count=0
            for j in range(n):
                if nums[i]==nums[j]:
                    count+=1
            if count>majority_element:
                return nums[i]

        
        
